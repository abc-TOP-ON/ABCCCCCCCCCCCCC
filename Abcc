_G.CashStealer = false
local eventConnection

-- دالة معالجة القطع والضغط فائق السرعة الحصري للـ PC
local function processItem(item)
    if not _G.CashStealer then return end
    
    if item.Name == "CashDrop" and (item:IsA("Part") or item:IsA("MeshPart")) then
        local fullName = item:GetFullName():lower()
        
        -- الفلاتر الصارمة لتجنب العوائق
        if not fullName:find("table") and not fullName:find("board") and 
           not fullName:find("game") and not fullName:find("ludo") and 
           not fullName:find("جلسة") and not fullName:find("طاولة") and
           not fullName:find("seat") and not fullName:find("chair") and 
           not fullName:find("bench") and not fullName:find("lockedframe") and  
           not fullName:find("barrier") then
            
            -- فحص البرومبت أو اللوحة بشكل فوري متوازي بدون تأخير ثواني
            if item:FindFirstChildOfClass("BillboardGui") or item:FindFirstChildOfClass("ProximityPrompt") or item:FindFirstChildOfClass("ClickDetector") then
                local player = game.Players.LocalPlayer
                local character = player.Character or player.CharacterAdded:Wait()
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                
                if rootPart then
                    local originalPosition = rootPart.CFrame
                    rootPart.CFrame = item.CFrame
                    
                    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("CashDrop", true)
                    
                    -- محرك الضغط الخارق للـ PC (يقوم بالضغط عشرات المرات في الثانية الواحدة بناءً على فريمات الشاشة)
                    local connection
                    connection = RunService.RenderStepped:Connect(function()
                        if not item or not item.Parent or not _G.CashStealer then
                            if connection then connection:Disconnect() end
                            return
                        end
                        
                        -- 1. إرسال ريموت فوري
                        if remote and remote:IsA("RemoteEvent") then
                            remote:FireServer(item)
                        end
                        
                        -- 2. تفعيل فوري للـ ProximityPrompt المخصص للمحترفين على الـ PC
                        local prompt = item:FindFirstChildOfClass("ProximityPrompt")
                        if prompt then 
                            fireproximityprompt(prompt)
                        end
                        
                        -- 3. تفعيل فوري للـ ClickDetector
                        local clicker = item:FindFirstChildOfClass("ClickDetector")
                        if clicker then 
                            fireclickdetector(clicker)
                        end
                    end)
                    
                    -- الانتظار حتى اختفاء القطعة تماماً لضمان عدم التعليق
                    repeat task.wait() until not item or not item.Parent or not _G.CashStealer
                    
                    if connection then connection:Disconnect() end
                    
                    if _G.CashStealer then
                        rootPart.CFrame = originalPosition
                    end
                end
            end
        end
    end
end

-- تشغيل الرصد والربط الفوري المتزامن
local function startStealing()
    for _, item in pairs(workspace:GetDescendants()) do
        if item.Name == "CashDrop" then
            task.spawn(function() pcall(processItem, item) end)
        end
    end
    
    eventConnection = workspace.DescendantAdded:Connect(function(item)
        if item.Name == "CashDrop" then
            task.spawn(function() pcall(processItem, item) end) -- استخدام task.spawn الفوري عند نزول أي كاش جديد
        end
    end)
end

-- زر تفعيل النظام وعكس الحالة
ToggleButton.MouseButton1Click:Connect(function()
    _G.CashStealer = not _G.CashStealer
    if _G.CashStealer then
        ToggleButton.Text = "ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        startStealing()
    else
        ToggleButton.Text = "OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(220, 40, 40)
        if eventConnection then
            eventConnection:Disconnect()
            eventConnection = nil
        end
    end
end)
