local function createInfoCard2(icon, title, value, color)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0.92, 0, 0, 55)
    card.Position = UDim2.new(0.04, 0, 0, 5)
    card.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
