-- دالة إشعارات صفحة المعلومات
function ShowInfoNotification(text)
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 280, 0, 35)
    notif.Position = UDim2.new(0.5, -140, 0.85, 0)
    notif.BackgroundColor3 = Color3.fromRGB(0, 80, 0)
    notif.BackgroundTransparency = 0.2
    notif.TextColor3 = Color3.fromRGB(0, 255, 150)
    notif.TextSize = 13
    notif.Font = Enum.Font.GothamBold
    notif.Text = text
    notif.Parent = InfoFrame
    notif.ZIndex = 50
    
    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 8)
    notifCorner.Parent = notif
    
    task.wait(2)
    notif:Destroy()
end

-- دالة عرض صفحة المعلومات
local function ShowInfo()
    HomeContainer.Visible = false
    WelcomeContainer.Visible = false
    TeleportContainer.Visible = false
    MoneyContainer.Visible = false
    FishingContainer.Visible = false
    PlayerContainer.Visible = false
    SettingsContainer.Visible = false
    NewsContainer.Visible = false
    InfoContainer.Visible = true
    
    for _, child in pairs(Sidebar:GetChildren()) do
        if child:IsA("TextButton") then
            if child.Text == "📋 المعلومات" then
                child.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
                child.TextColor3 = Color3.fromRGB(0, 0, 0)
            else
                child.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    end
end
