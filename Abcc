-- الزر الأول: تفعيل الجاذبية المعلقة (تشغيل/إطفاء وضع الطيران العام)
ToggleButton.Name = "ToggleButton"
ToggleButton.Parent = MainFrame
ToggleButton.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
ToggleButton.Position = UDim2.new(0.05, 0, 0.1, 0)
ToggleButton.Size = UDim2.new(0, 160, 0, 45)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.Text = "وضع الطيران: مطفأ ❌"
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.TextSize = 16
UICorner2.Parent = ToggleButton

ToggleButton.MouseButton1Click:Connect(function()
    local car = GetVehicle()
    if not car then
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "تنبيه",
            Text = "يجب أن تجلس في مقعد السائق أولاً!",
            Duration = 3
        })
        return
    end
    
    Flying = not Flying
    if Flying then
        ToggleButton.Text = "الوضع: معلقة بالهواء ✈️"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(40, 180, 70)
    else
        ToggleButton.Text = "وضع الطيران: مطفأ ❌"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        MovingForward = false
        MoveButton.Text = "حركة السيارة: متوقفة 🛑"
        MoveButton.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
    end
end)

