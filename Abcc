local function ShowNews()
    -- إخفاء جميع الصفحات الأخرى
    HomeContainer.Visible = false
    WelcomeContainer.Visible = false
    TeleportContainer.Visible = false
    MoneyContainer.Visible = false
    FishingContainer.Visible = false
    PlayerContainer.Visible = false
    SettingsContainer.Visible = false
    -- إظهار الأخبار
    NewsContainer.Visible = true
    
    -- تغيير ألوان الأزرار
    for _, child in pairs(Sidebar:GetChildren()) do
        if child:IsA("TextButton") then
            if child.Text == "📰 الأخبار" then
                child.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
                child.TextColor3 = Color3.fromRGB(0, 0, 0)
            else
                child.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    end
end

