local function createNewsCard(icon, title, desc, color, isImportant)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0.94, 0, 0, isImportant and 70 or 60)
    card.Position = UDim2.new(0.03, 0, 0, newsY)
    card.BackgroundColor3 = isImportant and Color3.fromRGB(40, 20, 20) or Color3.fromRGB(28, 28, 42)
    card.BorderSizePixel = 0
    card.Parent = NewsScroll
    card.ZIndex = 7
    
    local cardCorner = Instance.new("UICorner")
    cardCorner.CornerRadius = UDim.new(0, 8)
    cardCorner.Parent = card
    
    -- إضاءة جانبية للأخبار المهمة
    if isImportant then
        local glowBar = Instance.new("Frame")
        glowBar.Size = UDim2.new(0, 4, 1, -8)
        glowBar.Position = UDim2.new(0, 0, 0, 4)
        glowBar.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        glowBar.BorderSizePixel = 0
        glowBar.Parent = card
        glowBar.ZIndex = 8
        
        local glowBarCorner = Instance.new("UICorner")
        glowBarCorner.CornerRadius = UDim.new(0, 4)
        glowBarCorner.Parent = glowBar
    end
    
    -- الأيقونة
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, 40, 1, 0)
    iconLabel.Position = UDim2.new(0, 6, 0, 0)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Text = icon
    iconLabel.TextColor3 = color or Color3.fromRGB(255, 255, 255)
    iconLabel.TextSize = isImportant and 26 or 22
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.TextXAlignment = Enum.TextXAlignment.Center
    iconLabel.Parent = card
    iconLabel.ZIndex = 8
    
    -- العنوان
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -55, 0, 22)
    titleLabel.Position = UDim2.new(0, 50, 0, 4)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = isImportant and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(255, 200, 0)
    titleLabel.TextSize = isImportant and 15 or 14
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = card
    titleLabel.ZIndex = 8
    
    -- الوصف
    local descLabel = Instance.new("TextLabel")
    descLabel.Size = UDim2.new(1, -55, 0, isImportant and 34 or 28)
    descLabel.Position = UDim2.new(0, 50, 0, 26)
    descLabel.BackgroundTransparency = 1
    descLabel.Text = desc
    descLabel.TextColor3 = isImportant and Color3.fromRGB(255, 200, 200) or Color3.fromRGB(180, 180, 200)
    descLabel.TextSize = 12
    descLabel.Font = Enum.Font.GothamMedium
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.TextWrapped = true
    descLabel.Parent = card
    descLabel.ZIndex = 8
    
    newsY = newsY + (isImportant and 78 or 68)
    return card
end

