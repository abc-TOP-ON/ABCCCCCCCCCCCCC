-- قم بنسخ هذا الكود بالكامل ولصقه في منفذ دلتا (Delta Executor)
local Player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")

local Flying = false
local MovingForward = false
local Speed = 2.5 -- سرعة اندفاع السيارة (يمكنك زيادتها)

-- دالة جلب السيارة
local function GetVehicle()
    if Player.Character and Player.Character:FindFirstChild("Humanoid") then
        local Seat = Player.Character.Humanoid.SeatPart
        if Seat and Seat:IsA("VehicleSeat") then
            return Seat.Parent
        end
    end
    return nil
end

-- حلقة التثبيت والتحرك في الخلفية
RunService.Heartbeat:Connect(function()
    if Flying then
        local car = GetVehicle()
        if car then
            local PrimaryPart = car.PrimaryPart or car:FindFirstChildWhichIsA("BasePart")
            if PrimaryPart then
                local cam = workspace.CurrentCamera
                local lookVector = cam.CFrame.LookVector
                
                -- تحديد الحركة بناءً على حالة الزر (مفعل أو معطل)
                local moveDirection = Vector3.new(0, 0, 0)
                if MovingForward then
                    moveDirection = lookVector * Speed
                end
                
                local currentPos = PrimaryPart.Position
                local nextPos = currentPos + moveDirection
                
                -- تثبيت الزوايا ومنع الانقلاب
                PrimaryPart.CFrame = CFrame.new(nextPos, nextPos + Vector3.new(lookVector.X, 0, lookVector.Z))
                PrimaryPart.Velocity = Vector3.new(0, 0, 0) -- إلغاء الجاذبية
                PrimaryPart.RotVelocity = Vector3.new(0, 0, 0) -- منع الدوران العشوائي
            end
        else
            Flying = false
            MovingForward = false
        end
    end
end)

-- بناء واجهة مستخدم (GUI) متوافقة مع القوائم
