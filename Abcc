    card.Parent = InfoScroll
    card.ZIndex = 7
    
    local cardCorner = Instance.new("UICorner")
    cardCorner.CornerRadius = UDim.new(0, 8)
    cardCorner.Parent = card
    
    -- أيقونة
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, 45, 1, 0)
    iconLabel.Position = UDim2.new(0, 8, 0, 0)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Text = icon
    iconLabel.TextColor3 = color or Color3.fromRGB(255, 255, 255)
    iconLabel.TextSize = 28
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.TextXAlignment = Enum.TextXAlignment.Center
    iconLabel.Parent = card
    iconLabel.ZIndex = 8
    
    -- العنوان
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -60, 0, 20)
    titleLabel.Position = UDim2.new(0, 55, 0, 4)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = Color3.fromRGB(200, 200, 220)
    titleLabel.TextSize = 12
    titleLabel.Font = Enum.Font.GothamMedium
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = card
    titleLabel.ZIndex = 8
    
    -- القيمة
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(1, -60, 0, 24)
    valueLabel.Position = UDim2.new(0, 55, 0, 24)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = value
    valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    valueLabel.TextSize = 15
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextXAlignment = Enum.TextXAlignment.Left
    valueLabel.TextWrapped = true
    valueLabel.Parent = card
    valueLabel.ZIndex = 8
    
    return card
end

-- دالة إنشاء بطاقة مطور
local function createDeveloperCard(icon, title, discordName, role, color, isOwner)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0.92, 0, 0, 70)
    card.Position = UDim2.new(0.04, 0, 0, 5)
    card.BackgroundColor3 = isOwner and Color3.fromRGB(40, 20, 20) or Color3.fromRGB(20, 30, 50)
    card.BorderSizePixel = 0
    card.Parent = InfoScroll
    card.ZIndex = 7
    
    -- حدود ذهبية للأونر
    if isOwner then
        local border = Instance.new("Frame")
        border.Size = UDim2.new(1, 0, 1, 0)
        border.Position = UDim2.new(0, 0, 0, 0)
        border.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
        border.BackgroundTransparency = 0.6
        border.BorderSizePixel = 0
        border.Parent = card
        border.ZIndex = 6
        
        local borderCorner = Instance.new("UICorner")
        borderCorner.CornerRadius = UDim.new(0, 8)
        borderCorner.Parent = border
    end
    
    local cardCorner = Instance.new("UICorner")
    cardCorner.CornerRadius = UDim.new(0, 8)
    cardCorner.Parent = card
    
    -- أيقونة
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, 45, 1, 0)
    iconLabel.Position = UDim2.new(0, 8, 0, 0)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Text = icon
    iconLabel.TextColor3 = color or Color3.fromRGB(255, 255, 255)
    iconLabel.TextSize = 30
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.TextXAlignment = Enum.TextXAlignment.Center
    iconLabel.Parent = card
    iconLabel.ZIndex = 8
    
    -- دور المطور
    local roleLabel = Instance.new("TextLabel")
    roleLabel.Size = UDim2.new(1, -60, 0, 18)
    roleLabel.Position = UDim2.new(0, 55, 0, 4)
    roleLabel.BackgroundTransparency = 1
    roleLabel.Text = role
    roleLabel.TextColor3 = isOwner and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(88, 101, 242)
    roleLabel.TextSize = 11
    roleLabel.Font = Enum.Font.GothamBold
    roleLabel.TextXAlignment = Enum.TextXAlignment.Left
    roleLabel.Parent = card
    roleLabel.ZIndex = 8
    
    -- اسم الديسكورد
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -60, 0, 24)
    nameLabel.Position = UDim2.new(0, 55, 0, 24)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = discordName
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextSize = 16
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = card
    nameLabel.ZIndex = 8
    
    -- زر نسخ الديسكورد
    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0, 30, 0, 30)
    copyBtn.Position = UDim2.new(1, -38, 0.5, -15)
    copyBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
    copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    copyBtn.TextSize = 16
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.Text = "📋"
    copyBtn.Parent = card
    copyBtn.ZIndex = 9
    
    local copyCorner = Instance.new("UICorner")
    copyCorner.CornerRadius = UDim.new(0, 6)
    copyCorner.Parent = copyBtn
    
    copyBtn.MouseEnter:Connect(function()
        copyBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 95)
    end)
    copyBtn.MouseLeave:Connect(function()
        copyBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
    end)
    
    copyBtn.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(discordName)
            ShowInfoNotification("✅ تم نسخ ديسكورد: " .. discordName)
        end
    end)
    
    return card
end

