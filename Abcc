MoveButton.MouseButton1Click:Connect(function()
    if not Flying then return end -- لا يعمل إلا إذا كان وضع الطيران العام مشغلاً
    
    MovingForward = not MovingForward
    if MovingForward then
        MoveButton.Text = "حركة السيارة: تندفع ➔"
        MoveButton.BackgroundColor3 = Color3.fromRGB(0, 120, 255) -- أزرق أثناء الاندفاع
    else
        MoveButton.Text = "حركة السيارة: متوقفة 🛑"
        MoveButton.BackgroundColor3 = Color3.fromRGB(220, 60, 60) -- أحمر عند التوقف الثابت
    end
end)
