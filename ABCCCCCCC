        StatusLabel.Text = "⏸️ متوقف"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        if eventConnection then
            eventConnection:Disconnect()
            eventConnection = nil
        end
        showNotification("⛔ تم إيقاف تجميع الفلوس", MoneyFrame)
