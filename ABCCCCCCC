-- جعل الزر قابل للسحب
local dragging = false
local dragInput, dragStart, startPos

ToggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = ToggleButton.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

ToggleButton.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if dragging then
            local delta = input.Position - dragStart
            ToggleButton.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end
end)

-- تأثيرات الحركة على الحلقات
local ringColors = {
    Color3.fromRGB(120, 0, 255),
    Color3.fromRGB(180, 0, 255),
    Color3.fromRGB(220, 0, 255),
    Color3.fromRGB(180, 0, 255),
    Color3.fromRGB(120, 0, 255)
}

local colorIndex = 1

-- حلقة التحديث المستمر للنيون
task.spawn(function()
    while ScreenGui and ToggleButton.Parent do
        -- تحديث ألوان الحلقات
        colorIndex = colorIndex + 0.02
        local index = math.floor(colorIndex) % #ringColors + 1
        local nextIndex = index % #ringColors + 1
        local alpha = colorIndex % 1
        
        local currentColor = ringColors[index]
        local nextColor = ringColors[nextIndex]
        
        local r = currentColor.R + (nextColor.R - currentColor.R) * alpha
        local g = currentColor.G + (nextColor.G - currentColor.G) * alpha
        local b = currentColor.B + (nextColor.B - currentColor.B) * alpha
        
        local finalColor = Color3.new(r, g, b)
        
        -- تحديث لون النيون
        NeonRing.BackgroundColor3 = finalColor
        NeonRing.BorderColor3 = finalColor
        
        -- نبض الشفافية
        local breathe = 0.2 + math.sin(tick() * 2.5) * 0.2
        NeonRing.BackgroundTransparency = breathe
        PulseRing.BackgroundTransparency = breathe + 0.2
        
        -- تغيير حجم الحلقة النابضة
        local pulseSize = 1.5 + math.sin(tick() * 2) * 0.1
        PulseRing.Size = UDim2.new(pulseSize, 0, pulseSize, 0)
        PulseRing.Position = UDim2.new(-(pulseSize-1)/2, 0, -(pulseSize-1)/2, 0)
        
        task.wait(0.03)
    end
end)

