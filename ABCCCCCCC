local function createInfoCard(title, value, icon, row, col)
    local Card = Instance.new("Frame")
    Card.Size = UDim2.new(0.46, -10, 0, 50)
    Card.Position = UDim2.new(
        col == 1 and 0.02 or 0.52,
        0,
        0,
        148 + ((row - 1) * 60)
    )
    Card.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    Card.BorderSizePixel = 0
    Card.Parent = HomeContainer
    Card.ZIndex = 2

    local CardCorner = Instance.new("UICorner")
    CardCorner.CornerRadius = UDim.new(0, 8)
    CardCorner.Parent = Card

    Card.MouseEnter:Connect(function()
        Card.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
    end)
    Card.MouseLeave:Connect(function()
        Card.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    end)

    local IconLabel = Instance.new("TextLabel")
    IconLabel.Size = UDim2.new(0, 32, 1, 0)
    IconLabel.Position = UDim2.new(0, 6, 0, 0)
    IconLabel.BackgroundTransparency = 1
    IconLabel.Text = icon
    IconLabel.TextColor3 = Color3.fromRGB(180, 0, 255)
    IconLabel.TextSize = 22
    IconLabel.Font = Enum.Font.GothamBold
    IconLabel.TextXAlignment = Enum.TextXAlignment.Center
    IconLabel.Parent = Card
    IconLabel.ZIndex = 3

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, -45, 0, 18)
    TitleLabel.Position = UDim2.new(0, 42, 0, 4)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = title
    TitleLabel.TextColor3 = Color3.fromRGB(180, 0, 255)
    TitleLabel.TextSize = 11
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Parent = Card
    TitleLabel.ZIndex = 3

    local ValueLabel = Instance.new("TextLabel")
    ValueLabel.Size = UDim2.new(1, -45, 0, 22)
    ValueLabel.Position = UDim2.new(0, 42, 0, 22)
    ValueLabel.BackgroundTransparency = 1
    ValueLabel.Text = value
    ValueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    ValueLabel.TextSize = 13
    ValueLabel.Font = Enum.Font.GothamSemibold
    ValueLabel.TextXAlignment = Enum.TextXAlignment.Left
    ValueLabel.Parent = Card
    ValueLabel.ZIndex = 3
end

