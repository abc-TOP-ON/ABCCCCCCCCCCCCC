-- متغيرات الإعدادات (القيم الافتراضية = nil يعني ما نغير شيء)
local playerSettings = {
    speed = nil,  -- nil = يخلي السرعة طبيعية
    jumpPower = nil,
    gravity = nil
}

-- دالة تطبيق الإعدادات (تطبق فقط القيم اللي غيرها اللاعب)
function ApplySettings()
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            -- فقط إذا اللاعب غير القيمة (يعني مو nil)
            if playerSettings.speed ~= nil then
                humanoid.WalkSpeed = playerSettings.speed
            end
            if playerSettings.jumpPower ~= nil then
                humanoid.JumpPower = playerSettings.jumpPower
            end
            if playerSettings.gravity ~= nil then
                humanoid.Gravity = playerSettings.gravity
            end
        end
    end
end

