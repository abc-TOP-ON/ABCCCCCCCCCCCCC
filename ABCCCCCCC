local function createSidebarButton(text, posIndex, isActive, pageName)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, -20, 0, 40)
    Btn.Position = UDim2.new(0, 10, 0, 60 + ((posIndex - 1) * 48))
    
    if isActive then
        Btn.BackgroundColor3 = Color3.fromRGB(180, 0, 255)
        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    else
        Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
    
    Btn.BorderSizePixel = 0
    Btn.Text = text
    Btn.TextSize = 14
    Btn.Font = Enum.Font.GothamBold
    Btn.Parent = Sidebar
    Btn.ZIndex = 17

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 8)
    BtnCorner.Parent = Btn
    
    Btn.MouseEnter:Connect(function()
        if not isActive then
            Btn.BackgroundColor3 = Color3.fromRGB(70, 70, 95)
        end
    end)
    Btn.MouseLeave:Connect(function()
        if not isActive then
            Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
        end
    end)
    
    Btn.MouseButton1Click:Connect(function()
        HomeContainer.Visible = false
        WelcomeContainer.Visible = false
        TeleportContainer.Visible = false
        SettingsContainer.Visible = false
        
        if pageName == "Home" then
            HomeContainer.Visible = true
        elseif pageName == "Welcome" then
            WelcomeContainer.Visible = true
        elseif pageName == "Teleport" then
            TeleportContainer.Visible = true
        elseif pageName == "Settings" then
            SettingsContainer.Visible = true
        end
        
        for _, child in pairs(Sidebar:GetChildren()) do
            if child:IsA("TextButton") and child ~= Btn then
                child.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
        Btn.BackgroundColor3 = Color3.fromRGB(180, 0, 255)
        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    
    if isActive then
        local Indicator = Instance.new("Frame")
        Indicator.Size = UDim2.new(0, 4, 1, -12)
        Indicator.Position = UDim2.new(0, 4, 0, 6)
        Indicator.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        Indicator.BorderSizePixel = 0
        Indicator.Parent = Btn
        Indicator.ZIndex = 18
    end
    
    return Btn
end

