-- 5. تحريك الإطار البنفسجي
local glowColors = {
    Color3.fromRGB(120, 0, 255),
    Color3.fromRGB(180, 0, 255),
    Color3.fromRGB(220, 0, 255),
    Color3.fromRGB(180, 0, 255),
    Color3.fromRGB(120, 0, 255)
}

local colorIndex = 1
RunService.Heartbeat:Connect(function()
    colorIndex = colorIndex + 0.02
    local index = math.floor(colorIndex) % #glowColors + 1
    local nextIndex = index % #glowColors + 1
    local alpha = colorIndex % 1
    
    local currentColor = glowColors[index]
    local nextColor = glowColors[nextIndex]
    
    local r = currentColor.R + (nextColor.R - currentColor.R) * alpha
    local g = currentColor.G + (nextColor.G - currentColor.G) * alpha
    local b = currentColor.B + (nextColor.B - currentColor.B) * alpha
    
    GlowFrame.BackgroundColor3 = Color3.new(r, g, b)
    GlowFrame2.BackgroundColor3 = Color3.new(r + 0.1, g + 0.1, b + 0.1)
    
    local breathe = 0.2 + math.sin(tick() * 2) * 0.15
    GlowFrame.BackgroundTransparency = breathe
    GlowFrame2.BackgroundTransparency = breathe - 0.1
end)

