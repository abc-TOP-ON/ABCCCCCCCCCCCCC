    toggleBtn.Position = UDim2.new(0.76, 0, 0.5, -15)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggleBtn.TextSize = 12
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.Text = "إيقاف"
    toggleBtn.Parent = container
    toggleBtn.ZIndex = 8
    
    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 4)
    toggleCorner.Parent = toggleBtn
    
    local isActive = false
    
    toggleBtn.MouseButton1Click:Connect(function()
        local newState = false
        
        if settingName == "invisible" then
            newState = toggleInvisible()
        elseif settingName == "noclip" then
            newState = toggleNoclip()
        elseif settingName == "fly" then
            newState = toggleFly()
        elseif settingName == "autoRotate" then
            newState = toggleAutoRotate()
        elseif settingName == "fov120" then
            newState = toggleFOV120()
        end
        
        if newState then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
            toggleBtn.Text = "تفعيل"
            label.TextColor3 = Color3.fromRGB(0, 255, 150)
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            toggleBtn.Text = "إيقاف"
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
    end)
    
    return container
end

