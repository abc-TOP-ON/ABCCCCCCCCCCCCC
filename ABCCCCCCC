    -- عرض الإحداثيات داخل الزر
    local CoordsText = Instance.new("TextLabel")
    CoordsText.Size = UDim2.new(0.5, 0, 1, 0)
    CoordsText.Position = UDim2.new(0.5, 0, 0, 0)
    CoordsText.BackgroundTransparency = 1
    local x = math.floor(cframe.X * 10) / 10
    local y = math.floor(cframe.Y * 10) / 10
    local z = math.floor(cframe.Z * 10) / 10
    CoordsText.Text = "(" .. x .. ", " .. y .. ", " .. z .. ")"
    CoordsText.TextColor3 = Color3.fromRGB(200, 200, 200)
    CoordsText.TextSize = 10
    CoordsText.Font = Enum.Font.GothamMedium
    CoordsText.TextXAlignment = Enum.TextXAlignment.Right
    CoordsText.TextYAlignment = Enum.TextYAlignment.Center
    CoordsText.Parent = Btn
    CoordsText.ZIndex = 7
    
    -- تأثير Hover
    Btn.MouseEnter:Connect(function()
        Btn.BackgroundColor3 = Color3.new(color.R + 0.15, color.G + 0.15, color.B + 0.15)
        Btn.Size = UDim2.new(0.92, 0, 0, 42)
    end)
    Btn.MouseLeave:Connect(function()
        Btn.BackgroundColor3 = color
        Btn.Size = UDim2.new(0.9, 0, 0, 40)
    end)
    
    Btn.MouseButton1Click:Connect(function()
        teleportTo(cframe, placeName)
    end)
end

