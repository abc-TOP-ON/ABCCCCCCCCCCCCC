        StatusLabel.Text = "🟢 يعمل..."
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        collectedCount = 0
        CountLabel.Text = "📦 0"
        startStealing()
        showNotification("✅ تم تشغيل تجميع الفلوس الفوري!", MoneyFrame)
    else
