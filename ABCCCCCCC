local playerSettings = {
    speed = nil,
    jumpPower = nil,
    gravity = nil
}

local features = {
    invisible = false,
    noclip = false,
    fly = false,
    autoRotate = false,
    fov120 = false
}

local flyConnection = nil
local rotateConnection = nil
local currentRotation = 0
local originalFOV = Camera.FieldOfView

-- ============================================
-- دوال الميزات
-- ============================================

-- تطبيق الإعدادات الأساسية
function ApplySettings()
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            if playerSettings.speed ~= nil then
                humanoid.WalkSpeed = playerSettings.speed
            end
            if playerSettings.jumpPower ~= nil then
                humanoid.JumpPower = playerSettings.jumpPower
            end
            if playerSettings.gravity ~= nil then
                humanoid.Gravity = playerSettings.gravity
            end
        end
    end
end

-- دالة الاختفاء (Invisible)
local function toggleInvisible()
    features.invisible = not features.invisible
    local character = LocalPlayer.Character
    if character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                if features.invisible then
                    part.Transparency = 1
                    part.CanCollide = false
                else
                    part.Transparency = 0
                    part.CanCollide = true
                end
            end
            if part:IsA("Accessory") then
                if features.invisible then
                    part:SetAttribute("SavedTransparency", part.Handle.Transparency)
                    part.Handle.Transparency = 1
                else
                    part.Handle.Transparency = part:GetAttribute("SavedTransparency") or 0
                end
            end
        end
    end
    return features.invisible
end

-- دالة اختراق الجدران
local function toggleNoclip()
    features.noclip = not features.noclip
    local character = LocalPlayer.Character
    if character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = not features.noclip
            end
        end
    end
    return features.noclip
end

-- دالة الطيران
local function toggleFly()
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end
    
    features.fly = not features.fly
    
    if features.fly then
        humanoid.PlatformStand = true
        humanoid.AutoRotate = false
        
        if flyConnection then
            flyConnection:Disconnect()
            flyConnection = nil
        end
        
        flyConnection = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            if not char or not char.Parent then
                if flyConnection then
                    flyConnection:Disconnect()
                    flyConnection = nil
                end
                features.fly = false
                return
            end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChild("Humanoid")
            if not root or not hum then return end
            
            local camera = workspace.CurrentCamera
            if not camera then return end
            
            local forward = camera.CFrame.LookVector
            local right = camera.CFrame.RightVector
            local up = camera.CFrame.UpVector
            
            local flatForward = Vector3.new(forward.X, 0, forward.Z).Unit
            local flatRight = Vector3.new(right.X, 0, right.Z).Unit
            
            local moveDirection = Vector3.new(0, 0, 0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                moveDirection = moveDirection + flatForward
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                moveDirection = moveDirection - flatForward
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                moveDirection = moveDirection - flatRight
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                moveDirection = moveDirection + flatRight
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.E) then
                moveDirection = moveDirection + up
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then
                moveDirection = moveDirection - up
            end
            
            if moveDirection.Magnitude > 0 then
                moveDirection = moveDirection.Unit
                root.CFrame = root.CFrame + (moveDirection * 100 * 0.05)
            end
            
            hum.AutoRotate = false
        end)
    else
        if flyConnection then
            flyConnection:Disconnect()
            flyConnection = nil
        end
        humanoid.PlatformStand = false
        humanoid.AutoRotate = true
    end
    return features.fly
end

-- دالة الدوران التلقائي
local function toggleAutoRotate()
    features.autoRotate = not features.autoRotate
    
    if features.autoRotate then
        if rotateConnection then
            rotateConnection:Disconnect()
            rotateConnection = nil
        end
        currentRotation = 0
        rotateConnection = RunService.Heartbeat:Connect(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local root = LocalPlayer.Character.HumanoidRootPart
                currentRotation = currentRotation + 0.03
                root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, currentRotation, 0)
            end
        end)
    else
        if rotateConnection then
            rotateConnection:Disconnect()
            rotateConnection = nil
        end
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local root = LocalPlayer.Character.HumanoidRootPart
            root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, 0, 0)
        end
    end
    return features.autoRotate
end

-- دالة FOV 120
local function toggleFOV120()
    features.fov120 = not features.fov120
    
    if features.fov120 then
        Camera.FieldOfView = 120
        showNotification("👁️ تم تفعيل FOV 120", SettingsFrame)
    else
        Camera.FieldOfView = originalFOV
        showNotification("👁️ تم إلغاء FOV 120", SettingsFrame)
    end
    return features.fov120
end

