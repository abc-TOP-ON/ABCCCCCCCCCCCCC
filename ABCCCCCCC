-- وظيفة إظهار الصفحة الرئيسية
local function ShowHome()
    HomeContainer.Visible = true
    WelcomeContainer.Visible = false
    TeleportContainer.Visible = false
    -- تحديث حالة الأزرار
    for _, child in pairs(Sidebar:GetChildren()) do
        if child:IsA("TextButton") then
            if child.Text == "🏠 الرئيسية" then
                child.BackgroundColor3 = Color3.fromRGB(180, 0, 255)
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
            else
                child.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    end
end

-- وظيفة إظهار صفحة الترحيب
local function ShowWelcome()
    HomeContainer.Visible = false
    WelcomeContainer.Visible = true
    TeleportContainer.Visible = false
    -- تحديث حالة الأزرار
    for _, child in pairs(Sidebar:GetChildren()) do
        if child:IsA("TextButton") then
            if child.Text == "🎉 ترحيب" then
                child.BackgroundColor3 = Color3.fromRGB(180, 0, 255)
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
            else
                child.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    end
end

-- وظيفة إظهار صفحة الانتقال الفوري
local function ShowTeleport()
    HomeContainer.Visible = false
    WelcomeContainer.Visible = false
    TeleportContainer.Visible = true
    -- تحديث حالة الأزرار
    for _, child in pairs(Sidebar:GetChildren()) do
        if child:IsA("TextButton") then
            if child.Text == "⚡ انتقال الفوري" then
                child.BackgroundColor3 = Color3.fromRGB(180, 0, 255)
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
            else
                child.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
                child.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    end
end

-- ربط أزرار القائمة الجانبية
for _, child in pairs(Sidebar:GetChildren()) do
    if child:IsA("TextButton") then
        if child.Text == "🏠 الرئيسية" then
            child.MouseButton1Click:Connect(ShowHome)
        elseif child.Text == "🎉 ترحيب" then
            child.MouseButton1Click:Connect(ShowWelcome)
        elseif child.Text == "⚡ انتقال الفوري" then
            child.MouseButton1Click:Connect(ShowTeleport)
        end
    end
end

-- ربط أزرار العودة
BackButton.MouseButton1Click:Connect(ShowHome)
TeleportBackButton.MouseButton1Click:Connect(ShowHome)

