local function createTeleportButtons()
    local yOffset = 5
    local buttonHeight = 32
    local spacing = 6
    
    for i, place in ipairs(places) do
        local button = Instance.new("TextButton")
        button.Name = "TeleportBtn_" .. i
        button.Size = UDim2.new(0.92, 0, 0, buttonHeight)
        button.Position = UDim2.new(0.04, 0, 0, yOffset)
        button.BackgroundColor3 = place.color
        button.TextColor3 = Color3.fromRGB(255, 255, 255)
        button.TextSize = 13
        button.Font = Enum.Font.GothamSemibold
        button.Text = place.name
        button.Parent = TeleportScroll
        button.ZIndex = 7
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = button
        
        local origColor = place.color
        button.MouseEnter:Connect(function()
            button.BackgroundColor3 = Color3.new(
                math.min(origColor.R + 0.15, 1),
                math.min(origColor.G + 0.15, 1),
                math.min(origColor.B + 0.15, 1)
            )
        end)
        button.MouseLeave:Connect(function()
            button.BackgroundColor3 = origColor
        end)
        
        button.MouseButton1Click:Connect(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = place.cf
                task.wait(0.1)
                ApplySettings()
            end
        end)
        
        yOffset = yOffset + buttonHeight + spacing
    end
    
    TeleportScroll.CanvasSize = UDim2.new(0, 0, 0, yOffset + 10)
end

